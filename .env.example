# ============================================================================
# Friday_jarvis2 + Hermes-Agent + LiveKit Integration Configuration
# ============================================================================

# ============================================================================
# LIVEKIT CONFIGURATION
# ============================================================================
# Get these from https://cloud.livekit.io or deploy your own LiveKit server

# The WebSocket URL for LiveKit server (use ws:// for local, wss:// for prod)
LIVEKIT_URL=ws://livekit:7880

# API Key for LiveKit authentication
LIVEKIT_API_KEY=devkey

# API Secret for LiveKit authentication
LIVEKIT_API_SECRET=secret

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys

# OpenAI API Key (required for LLM functionality)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Specify model (defaults to gpt-4-realtime-preview-20241217)
# OPENAI_MODEL=gpt-4-realtime-preview-20241217

# ============================================================================
# GOOGLE CONFIGURATION
# ============================================================================
# Get from Google Cloud Console

# Google API Key (for weather, web search, and other Google services)
GOOGLE_API_KEY=your-google-api-key

# ============================================================================
# GMAIL CONFIGURATION
# ============================================================================
# Setup instructions:
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below

# Your Gmail address
GMAIL_USER=your-email@gmail.com

# Gmail App Password (16 characters from Google Account)
GMAIL_APP_PASSWORD=your-app-password-here

# ============================================================================
# MEM0 MEMORY SYSTEM CONFIGURATION
# ============================================================================
# Get API key from https://app.mem0.ai

# Mem0 API Key (for persistent memory system)
MEM0_API_KEY=your-mem0-api-key

# Optional: Mem0 API Base URL (defaults to https://api.mem0.ai)
# MEM0_API_BASE=https://api.mem0.ai

# ============================================================================
# MCP SERVER CONFIGURATION (Hermes Integration)
# ============================================================================
# This connects Friday to the Hermes-Agent for advanced capabilities

# URL of the N8N/Hermes MCP Server
# When using docker-compose: http://hermes-agent:8080
# When using local setup: http://localhost:8080
N8N_MCP_SERVER_URL=http://hermes-agent:8080

# ============================================================================
# SPOTIFY INTEGRATION (Optional - requires Hermes-Agent support)
# ============================================================================
# Setup instructions:
# 1. Create a Spotify app at https://developer.spotify.com/dashboard
# 2. Get Client ID and Secret from your app settings
# 3. Set Redirect URI in your app settings to match SPOTIFY_REDIRECT_URI

# Spotify Client ID
SPOTIFY_CLIENT_ID=your-spotify-client-id

# Spotify Client Secret
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Spotify Redirect URI (must match your Spotify app settings)
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ============================================================================
# N8N CONFIGURATION (Optional - requires docker-compose --profile optional)
# ============================================================================
# For running N8N within the Docker setup

# N8N URL for Hermes integration
N8N_URL=http://n8n:5678

# N8N API Key (generate in N8N settings)
N8N_API_KEY=your-n8n-api-key

# ============================================================================
# DATABASE CONFIGURATION (Optional - if Hermes uses database)
# ============================================================================

# Database URL for Hermes-Agent (if applicable)
# Examples:
# SQLite: sqlite:///./hermes.db
# PostgreSQL: postgresql://user:password@localhost/dbname
# DATABASE_URL=sqlite:///./hermes.db

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# User name for personalization
USER_NAME=David

# ============================================================================
# DEPLOYMENT CONFIGURATION (For Railway/Production)
# ============================================================================

# Railway deployment variables
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_SERVICE_NAME=friday-agent

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER commit your .env file with real API keys to GitHub
# 2. Use .env.example (this file) as a template
# 3. Copy to .env locally and fill with your actual keys
# 4. Add .env to .gitignore
# 5. For production/Railway deployment, use service environment variables
# 6. Rotate API keys periodically
# 7. Use strong passwords for app-specific passwords (like Gmail App Password)

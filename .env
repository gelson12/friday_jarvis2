LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

GOOGLE_API_KEY=
GMAIL_APP_PASSWORD=
GMAIL_USER=

MEM0_API_KEY=

OPENAI_API_KEY=

N8N_MCP_SERVER_URL=

# OpenCTI ("Global Eyes") integration — leave blank locally; set on the
# Railway worker service so the cloud worker can reach OpenCTI's
# GraphQL and fire the lifecycle workflow_dispatch.
OPENCTI_URL=
OPENCTI_TOKEN=
GITHUB_DISPATCH_TOKEN=
GITHUB_DISPATCH_OWNER=gelson12
GITHUB_DISPATCH_REPO=friday_jarvis2
GITHUB_DISPATCH_WORKFLOW=opencti-lifecycle.yml

# ── Accommodation booking (Phase 1: LiteAPI only) ────────────────────
# Sign up at https://liteapi.travel/ for a sandbox key. No credit card
# needed. See brain/Accommodation Booking — Implementation Plan in the
# Obsidian vault for the full design.
LITEAPI_KEY=
LITEAPI_ENV=sandbox
LITEAPI_AFFILIATE_MARKUP_PCT=10.0

# Apify Airbnb scraper (Phase 2, read-only discovery). Get a token at
# https://console.apify.com/account/integrations — free tier works.
# Provider activates only when this is set; aggregator dedups against LiteAPI.
APIFY_TOKEN=
APIFY_AIRBNB_ACTOR=tri_angle~airbnb-scraper
APIFY_AIRBNB_TIMEOUT_S=60

# Default guest details used for bookings. Voice-dictating an email is
# awful UX, so we pull these from env. Override per-booking later when
# we add multi-traveler support.
ACCOMMODATION_GUEST_FIRST_NAME=
ACCOMMODATION_GUEST_LAST_NAME=
ACCOMMODATION_GUEST_EMAIL=
ACCOMMODATION_DEFAULT_CURRENCY=GBP

# Telegram delivery for the PCI-safe payment magic-link. Reuses the
# existing TELEGRAM_BOT_TOKEN; supply a default chat id for "send to me".
TELEGRAM_DEFAULT_CHAT_ID=

# Vault writer (fj2 runs on Railway → must use HTTP, not local FS).
# Optional bearer token enables auth on the obsidian-mind service —
# set the same value here AND on the obsidian-mind Railway env.
OBSIDIAN_MIND_URL=https://obsidian-mind-production-b3f9.up.railway.app
OBSIDIAN_MIND_TOKEN=
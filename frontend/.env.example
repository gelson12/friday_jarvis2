# LiveKit project credentials.
# Use the SAME project as the friday_jarvis2 `br` agent so the UI and the
# agent rendezvous in the same LiveKit Cloud room (project jarvis-98rhrfmj).
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>

# Agent dispatch. Leave BLANK for automatic dispatch — the `br` agent worker
# registers with no agent_name, so any room created here auto-assigns it.
AGENT_NAME=

# Leave UNSET in self-hosted mode. Setting this switches the client to the
# LiveKit Cloud sandbox token source instead of the built-in /api/token route.
# NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=

# Server port (Railway injects PORT automatically; default 3000).
PORT=3000

# OpenCTI ("Global Eyes") — the public Railway URL for the OpenCTI
# platform service. Baked into the bundle at build time, so trigger a
# redeploy on the frontend service after setting it. Leave blank for
# now; the worker will pass the URL in the widget payload at runtime as
# a fallback when this is empty.
NEXT_PUBLIC_OPENCTI_URL=

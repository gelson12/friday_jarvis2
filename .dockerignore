# ─── Git ─────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github/

# ─── Python build artefacts (everywhere) ─────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.pytest_cache/
.coverage

# ─── Python local venvs (everywhere) ─────────────────────────────
venv/
env/
ENV/
.venv/
**/venv/
**/.venv/

# ─── Node / Next.js build artefacts (rebuilt fresh in stage 1) ───
node_modules/
**/node_modules/
.next/
**/.next/
npm-debug.log

# ─── Local env / secrets (Railway provides at runtime) ───────────
.env
.env.local
.env.*.local
.env.example

# ─── IDE / OS noise ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─── Documentation (none of it ships in the image) ───────────────
*.md
LICENSE
docs/

# ─── Tests (worker has no runtime tests) ─────────────────────────
test_*.py
tests/

# ─── Docker / CI files (not needed inside the container) ─────────
Dockerfile
docker-compose.yml
.dockerignore
.gitlab-ci.yml
.travis.yml

# ─── Sibling sandbox / debug folders that ship in this repo
#     but never run inside the container.
desktop-mcp-server/
friday_jarvis2/
workflow_exports/

# ─── Claude / project-memory state ───────────────────────────────
.claude/

# ─── Misc ────────────────────────────────────────────────────────
*.log
*.pot

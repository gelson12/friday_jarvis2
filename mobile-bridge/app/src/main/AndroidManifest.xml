<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service to stay connected to LiveKit when the screen is off -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- CRITICAL: lets the background bridge actually LAUNCH apps/activities. Without the
         "Display over other apps" grant, Android 10+ silently blocks startActivity from the
         background, so open_app reports success but nothing appears. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Phone control -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- LiveKit SDK requires it for the device-info probe even though we publish no audio -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Needed to list all installed packages (for fuzzy "open <app>" matching).
         Google Play would require a justification; sideloaded APK is fine. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- App-launch deep-links use these query-tag filters on Android 11+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="tel" />
        </intent>
        <package android:name="com.whatsapp" />
        <package android:name="com.instagram.android" />
        <package android:name="com.facebook.katana" />
        <package android:name="com.facebook.orca" />
        <package android:name="com.zhiliaoapp.musically" />  <!-- TikTok -->
        <package android:name="com.google.android.youtube" />
        <package android:name="com.android.chrome" />
    </queries>

    <application
        android:label="Jarvis Mobile Bridge"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".JarvisActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:hardwareAccelerated="true" />

        <service
            android:name=".BridgeService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- OPTIONAL WhatsApp auto-send. Disabled until the user enables it under
             Settings → Accessibility. Scoped to com.whatsapp only (see the xml). -->
        <service
            android:name=".WhatsAppSendService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/whatsapp_send_service" />
        </service>

    </application>
</manifest>
